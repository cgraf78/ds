# Tests: Profile resolution
# ---------------------------------------------------------------------------

echo ""
echo "=== Profile resolution ==="

# Empty SESSION defaults to "ds" with ds profile
SESSION="" PROFILE=""
_resolve_profile
_assert_eq "empty SESSION → SESSION=ds" "ds" "$SESSION"
_assert_eq "empty SESSION → PROFILE=ds" "ds" "$PROFILE"

# Exact profile match
SESSION="dev" PROFILE=""
_resolve_profile
_assert_eq "SESSION=dev → PROFILE=dev" "dev" "$PROFILE"
_assert_eq "SESSION=dev unchanged" "dev" "$SESSION"

SESSION="web" PROFILE=""
_resolve_profile
_assert_eq "SESSION=web → PROFILE=web" "web" "$PROFILE"

SESSION="ds" PROFILE=""
_resolve_profile
_assert_eq "SESSION=ds → PROFILE=ds" "ds" "$PROFILE"

# Profile-instance (dash-separated)
SESSION="dev-work" PROFILE=""
_resolve_profile
_assert_eq "dev-work → PROFILE=dev" "dev" "$PROFILE"
_assert_eq "dev-work SESSION preserved" "dev-work" "$SESSION"

SESSION="dev-frontend" PROFILE=""
_resolve_profile
_assert_eq "dev-frontend → PROFILE=dev" "dev" "$PROFILE"

SESSION="web-2" PROFILE=""
_resolve_profile
_assert_eq "web-2 → PROFILE=web" "web" "$PROFILE"

# Multiple dashes — split on first
SESSION="dev-my-project" PROFILE=""
_resolve_profile
_assert_eq "dev-my-project → PROFILE=dev" "dev" "$PROFILE"
_assert_eq "dev-my-project SESSION preserved" "dev-my-project" "$SESSION"

# Unknown profile → error
result=$( (SESSION="foo" PROFILE=""; _resolve_profile) 2>&1 || true)
_assert_contains "unknown profile errors" "unknown profile" "$result"
_assert_contains "unknown profile lists options" "ds" "$result"

result=$( (SESSION="foo-bar" PROFILE=""; _resolve_profile) 2>&1 || true)
_assert_contains "unknown profile-instance errors" "unknown profile" "$result"

# ---------------------------------------------------------------------------
# Tests: Session target resolution
# ---------------------------------------------------------------------------

echo ""
echo "=== Session target resolution ==="

# Explicit session — passes through
SESSION="dev" HOST=""
_resolve_session_target
_assert_eq "explicit SESSION preserved" "dev" "$SESSION"

# Remote without session → error
result=$( (SESSION="" HOST="myhost"; _resolve_session_target) 2>&1 || true)
_assert_contains "remote without session errors" "session name required for remote" "$result"

# No session, no host, no tmux → error
# shellcheck disable=SC2030  # intentional — TMUX set in subshell for isolation
result=$( (SESSION="" HOST="" TMUX=""; _resolve_session_target) 2>&1 || true)
_assert_contains "no session, no tmux errors" "not inside tmux" "$result"

# Inside tmux, no session → defaults to current session
# shellcheck disable=SC2031  # intentional — TMUX set independently of subshell above
export TMUX="/tmp/tmux-test/default,12345,0"
export MOCK_CURRENT_SESSION="dev-work"
SESSION="" HOST=""
_resolve_session_target
_assert_eq "tmux default: resolves to current session" "dev-work" "$SESSION"
unset TMUX MOCK_CURRENT_SESSION

# ---------------------------------------------------------------------------
# Tests: Upterm sharing backend
# ---------------------------------------------------------------------------

echo ""
echo "=== Upterm sharing backend ==="

# _share_start launches upterm host in the background and polls for an admin
# socket. The mock upterm executes the hosted command to create it, and
# responds to "session current" with share info. Here we verify core behavior.

_reset_tmux_log
export MOCK_SESSIONS=""
export MOCK_DS_MANAGED=""
SESSION="ds"
PROFILE="ds"
DS_SHARE_VIA=""
DS_NO_ATTACH=1
DS_SHARE_INFO_FILE="$(_default_share_info_file)"
DS_UPTERM_PID_FILE="$(_upterm_pid_file)"
result=$(_do_session 2>&1)
log=$(_tmux_log)
_assert_contains "no-attach: creates tmux session" "tmux new-session -d -s ds" "$log"
if echo "$log" | grep -qx 'tmux attach -t =ds'; then
    _fail "no-attach: skips local attach"
else
    _pass "no-attach: skips local attach"
fi

# Test --share action with existing session
_reset_tmux_log
export MOCK_SESSIONS="ds"
DS_SHARE_VIA="upterm"
DS_UPTERM_GITHUB_USER="testuser"
SESSION="ds"
HOST=""
# _do_share calls _share_start, which runs the full share flow with mock upterm
result=$(_do_share 2>&1) || true
_assert_not_contains "share action: no 'no session' error for existing session" "no session" "$result"

# Test --share action with nonexistent session
_reset_tmux_log
export MOCK_SESSIONS=""
SESSION="nonexistent"
HOST=""
result=$(_do_share 2>&1) || true
_assert_contains "share action: error for nonexistent session" "no session" "$result"

# Clean up state from share test (kill mock upterm, remove PID/state files)
_pid_f=$(_upterm_pid_file)
if [[ -f "$_pid_f" ]]; then
    _pid=$(cat "$_pid_f" 2>/dev/null || true)
    if [[ "$_pid" =~ ^[0-9]+$ ]]; then kill "$_pid" 2>/dev/null || true; fi
    rm -f "$_pid_f"
fi
rm -f "$DS_SHARE_INFO_FILE" "$(_upterm_admin_file)" "$(_upterm_session_file)" "$(_upterm_log_file)"

# Test --unshare action (no daemon running)
SESSION="ds"
HOST=""
result=$(_do_unshare 2>&1)
_assert_contains "unshare: reports not sharing" "not currently sharing" "$result"

# Test normalization of upterm host output variants (e.g., WSL fallback log parse)
result=$(_upterm_normalize_info $'Command: ssh token123@uptermd.upterm.dev')
_assert_contains "normalize upterm: command format" "ssh: ssh token123@uptermd.upterm.dev" "$result"

# Test reading share info directly from upterm log fallback
log_file="$(_tmpdir)/upterm.log"
printf '%s\n' 'Some startup text' 'Command: ssh abc123@uptermd.upterm.dev' > "$log_file"
result=$(_upterm_read_info_from_log "$log_file")
_assert_contains "log fallback: extracts ssh command" "ssh: ssh abc123@uptermd.upterm.dev" "$result"

# Test PID validation — _share_running rejects non-numeric PID files
pid_dir=$(_tmpdir)
DS_UPTERM_PID_FILE="$pid_dir/test.pid"

echo "not-a-pid" > "$DS_UPTERM_PID_FILE"
if _share_running; then
    _fail "share_running: rejects non-numeric PID"
else
    _pass "share_running: rejects non-numeric PID"
fi

echo "12345; rm -rf /" > "$DS_UPTERM_PID_FILE"
if _share_running; then
    _fail "share_running: rejects PID with injection"
else
    _pass "share_running: rejects PID with injection"
fi

echo "" > "$DS_UPTERM_PID_FILE"
if _share_running; then
    _fail "share_running: rejects empty PID"
else
    _pass "share_running: rejects empty PID"
fi

rm -f "$DS_UPTERM_PID_FILE"
if _share_running; then
    _fail "share_running: rejects missing PID file"
else
    _pass "share_running: rejects missing PID file"
fi

# Test _share_load_config reads share-upterm.conf
cat > "$CONF_DIR/share-upterm.conf" <<'EOF'
# test config
server=myupterm.internal:2222
known-hosts=/path/to/known_hosts
private-key=/path/to/key
github-user=testghuser
authorized-keys=/path/to/authorized_keys
push=user@remotehost
EOF

# Clear env vars so config values take effect
DS_UPTERM_HOST=""
DS_UPTERM_KNOWN_HOSTS=""
DS_UPTERM_PRIVATE_KEY=""
DS_UPTERM_GITHUB_USER=""
DS_UPTERM_AUTHORIZED_KEYS=""
DS_UPTERM_PUSH=""
_share_load_config
_assert_eq "config: server" "myupterm.internal:2222" "$DS_UPTERM_HOST"
_assert_eq "config: known-hosts" "/path/to/known_hosts" "$DS_UPTERM_KNOWN_HOSTS"
_assert_eq "config: private-key" "/path/to/key" "$DS_UPTERM_PRIVATE_KEY"
_assert_eq "config: github-user" "testghuser" "$DS_UPTERM_GITHUB_USER"
_assert_eq "config: authorized-keys" "/path/to/authorized_keys" "$DS_UPTERM_AUTHORIZED_KEYS"
_assert_eq "config: push" "user@remotehost" "$DS_UPTERM_PUSH"

# Env vars override config values
DS_UPTERM_HOST="envhost:3333"
DS_UPTERM_KNOWN_HOSTS="/env/known_hosts"
DS_UPTERM_PRIVATE_KEY="/env/key"
DS_UPTERM_GITHUB_USER="envuser"
DS_UPTERM_AUTHORIZED_KEYS="/env/authorized_keys"
DS_UPTERM_PUSH="envuser@envhost"
_share_load_config
_assert_eq "env override: server" "envhost:3333" "$DS_UPTERM_HOST"
_assert_eq "env override: known-hosts" "/env/known_hosts" "$DS_UPTERM_KNOWN_HOSTS"
_assert_eq "env override: private-key" "/env/key" "$DS_UPTERM_PRIVATE_KEY"
_assert_eq "env override: github-user" "envuser" "$DS_UPTERM_GITHUB_USER"
_assert_eq "env override: authorized-keys" "/env/authorized_keys" "$DS_UPTERM_AUTHORIZED_KEYS"
_assert_eq "env override: push" "envuser@envhost" "$DS_UPTERM_PUSH"

# Missing config file is silently ignored
rm -f "$CONF_DIR/share-upterm.conf"
DS_UPTERM_HOST=""
DS_UPTERM_PUSH=""
_share_load_config
_assert_eq "missing config: server empty" "" "$DS_UPTERM_HOST"
_assert_eq "missing config: push empty" "" "$DS_UPTERM_PUSH"

# Reset sharing vars for remaining tmux tests
DS_SHARE_VIA=""
DS_NO_ATTACH=0
DS_SHARE_INFO_FILE=""
DS_UPTERM_PID_FILE=""
DS_UPTERM_GITHUB_USER=""
DS_UPTERM_AUTHORIZED_KEYS=""
DS_UPTERM_PUSH=""
SESSION=""
HOST=""

