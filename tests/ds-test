echo ""
echo "=== Remote command building ==="

# Install connection plugins for testing
# shellcheck disable=SC2016  # intentional — writing literal $1/$2 to file
cp "$SCRIPT_DIR/../lib/plugins/connect-autossh.sh" "$CONF_DIR/" 2>/dev/null || \
    printf '_connect_autossh() { exec autossh -M0 "$1" -t "$2"; }\n' > "$CONF_DIR/connect-autossh.sh"

# Mock ssh/autossh to capture args instead of connecting
cat > "$MOCK_BIN/ssh" <<'MOCK'
#!/usr/bin/env bash
# ssh is called as: ssh -t -- HOST CMD
# Skip flags/-- to find the host positional arg
_host=""
for _a in "$@"; do
    [[ "$_a" == --  ]] && continue
    [[ "$_a" == -* ]] && continue
    if [[ -z "$_host" ]]; then _host="$_a"; continue; fi
done
echo "SSH_HOST=$_host" > "${REMOTE_LOG:-/dev/null}"
echo "SSH_ARGS=$*" >> "${REMOTE_LOG:-/dev/null}"
MOCK
chmod +x "$MOCK_BIN/ssh"

cat > "$MOCK_BIN/autossh" <<'MOCK'
#!/usr/bin/env bash
echo "AUTOSSH_ARGS=$*" > "${REMOTE_LOG:-/dev/null}"
MOCK
chmod +x "$MOCK_BIN/autossh"

REMOTE_LOG="$MOCK_BIN/remote.log"
export REMOTE_LOG

# _remote calls exec, which doesn't play well with $() subshells.
# Run each test in a fresh bash process that sources ds.
# Uses timeout (Linux) or gtimeout (macOS/Homebrew) with bash fallback.
_timeout() {
    if command -v timeout >/dev/null 2>&1; then
        timeout "$@"
    elif command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$@"
    else
        # bash-native fallback: run in background, kill after $1 seconds
        local secs="$1"; shift
        "$@" &
        local pid=$!
        ( sleep "$secs"; kill "$pid" 2>/dev/null ) &
        local watchdog=$!
        wait "$pid" 2>/dev/null
        kill "$watchdog" 2>/dev/null
        wait "$watchdog" 2>/dev/null
    fi
}

_run_remote() {
    : > "$REMOTE_LOG"
    local env_args="$1"
    _timeout 3 bash -c "
        export DS_SOURCED=1
        . '$SCRIPT_DIR/../bin/ds'
        $env_args _remote
    " 2>&1 || true
}

# Test SSH remote dispatch (dev profile session)
result=$(_run_remote "HOST=server1 ACTION=session SESSION=dev \
    CONNECT_OVERRIDE=")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "ssh remote: host" "SSH_HOST=server1" "$remote_log"
# shellcheck disable=SC2088  # intentional — matching literal tilde in remote command
_assert_contains "ssh remote: runs ds" "~/.local/bin/ds" "$remote_log"
_assert_contains "ssh remote: passes session name" "dev" "$remote_log"

