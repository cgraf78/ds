    CONNECT_OVERRIDE=")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "remote kill: passes -k" "-k" "$remote_log"
_assert_contains "remote kill: passes target" "dev-myproject" "$remote_log"

# Test killall action on remote
